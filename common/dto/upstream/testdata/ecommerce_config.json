{
  "servie": "e-commerce",
  "host": {
    "api.shop.com": {
      "host": "product-service.internal:8080",
      "request": [
        {
          "path": "/products",
          "method": "GET",
          "requestTimeout": 3000,
          "responseTimeout": 5000,
          "checkAuthorization": false
        },
        {
          "path": "/products/{productId}",
          "method": "GET",
          "requestTimeout": 2000,
          "responseTimeout": 4000,
          "checkAuthorization": false
        },
        {
          "path": "/products/{productId}/reviews",
          "method": "GET",
          "requestTimeout": 5000,
          "responseTimeout": 8000,
          "checkAuthorization": false
        },
        {
          "path": "/products/{productId}/reviews/{reviewId}",
          "method": "GET",
          "requestTimeout": 3000,
          "responseTimeout": 5000,
          "checkAuthorization": true
        },
        {
          "path": "/categories",
          "method": "GET",
          "requestTimeout": 2000,
          "responseTimeout": 3000,
          "checkAuthorization": false
        },
        {
          "path": "/categories/{categoryId}",
          "method": "GET",
          "requestTimeout": 2000,
          "responseTimeout": 3000,
          "checkAuthorization": false
        },
        {
          "path": "/categories/{categoryId}/products",
          "method": "GET",
          "requestTimeout": 5000,
          "responseTimeout": 8000,
          "checkAuthorization": false
        }
      ]
    },
    "cart.shop.com": {
      "host": "cart-service.internal:8082",
      "request": [
        {
          "path": "/cart",
          "method": "GET",
          "requestTimeout": 3000,
          "responseTimeout": 5000,
          "checkAuthorization": true
        },
        {
          "path": "/cart/items",
          "method": "POST",
          "requestTimeout": 5000,
          "responseTimeout": 8000,
          "checkAuthorization": true
        },
        {
          "path": "/cart/items/{itemId}",
          "method": "DELETE",
          "requestTimeout": 3000,
          "responseTimeout": 5000,
          "checkAuthorization": true
        }
      ]
    },
    "order.shop.com": {
      "host": "order-service.internal:8083",
      "request": [
        {
          "path": "/orders",
          "method": "GET",
          "requestTimeout": 5000,
          "responseTimeout": 10000,
          "checkAuthorization": true
        },
        {
          "path": "/orders",
          "method": "POST",
          "requestTimeout": 10000,
          "responseTimeout": 15000,
          "checkAuthorization": true
        },
        {
          "path": "/orders/{orderId}",
          "method": "GET",
          "requestTimeout": 3000,
          "responseTimeout": 5000,
          "checkAuthorization": true
        },
        {
          "path": "/orders/{orderId}/status",
          "method": "GET",
          "requestTimeout": 2000,
          "responseTimeout": 3000,
          "checkAuthorization": true
        }
      ]
    }
  }
}
