          "method": "GET",
          "request_timeout": 1000,
          "response_timeout": 2000,
          "check_authorization": false
        }
      ]
    },
    {
      "sub_domain": "admin.example.com",
      "host": "admin-service.internal:8081",
      "paths": [
        {
