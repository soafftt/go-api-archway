          "request_timeout": 10000,
          "response_timeout": 15000,
          "check_authorization": true
        },
        {
          "path": "/admin/users/{id}",
          "method": "GET",
          "request_timeout": 5000,
          "response_timeout": 8000,
          "check_authorization": true
        },
        {
          "path": "/admin/settings",
          "method": "GET",
          "request_timeout": 5000,
          "response_timeout": 8000,
          "check_authorization": true
        }
      ]
    },
    {
      "sub_domain": "",
