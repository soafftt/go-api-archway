{
  "service_name": "ecommerce-api",
  "resources": [
    {
      "sub_domain": "api.shop.com",
      "host": "product-service.internal:8080",
      "paths": [
        {
          "path": "/products",
          "method": "GET",
          "request_timeout": 3000,
          "response_timeout": 5000,
          "check_authorization": false
        },
        {
          "path": "/products/{productId}",
          "method": "GET",
          "request_timeout": 2000,
          "response_timeout": 4000,
          "check_authorization": false
        }
      ]
    },
    {
      "sub_domain": "cart.shop.com",
      "host": "cart-service.internal:8082",
      "paths": [
        {
          "path": "/cart",
          "method": "GET",
          "request_timeout": 3000,
          "response_timeout": 5000,
          "check_authorization": true
        },
        {
          "path": "/cart/items",
          "method": "POST",
          "request_timeout": 5000,
          "response_timeout": 8000,
          "check_authorization": true
        }
      ]
    },
    {
      "sub_domain": "",
      "host": "shop-default.internal:8090",
      "paths": [
        {
          "path": "/v1/member/",
          "method": "GET",
          "request_timeout": 1000,
          "response_timeout": 1000,
          "check_authorization": true,
          "cache_timeout": 10
        }
      ]
    }
  ]
}
